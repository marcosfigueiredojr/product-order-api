{
  "family": "product-order-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "product-order-api",
      "image": "747030889225.dkr.ecr.us-east-1.amazonaws.com/product-order-api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "api-8080-tcp",
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/product-order-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}